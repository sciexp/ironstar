# shellcheck shell=bash
if ! has nix_direnv_version || ! nix_direnv_version "3.1.1"; then
  source_url "https://raw.githubusercontent.com/nix-community/nix-direnv/3.1.1/direnvrc" "sha256-p+fzQdrms/hDa7g+soShAybJNo4bN4SIAeSfqNKgD5I="
fi

watch_file \
  modules/*.nix \
  modules/**/*.nix \
  crates/*/crate.nix \
  rust-toolchain.toml \
  Cargo.toml \
  Cargo.lock \
  package.json \
  bun.lock

if ! use flake .#default --impure --accept-flake-config --print-build-logs; then
  echo "nix flake could not be built; update flake.nix and run direnv allow/reload" >&2
fi

dotenv
